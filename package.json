{
  "name": "llm-oj",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "24.3.0",
    "npm": ">=11.4.2"
  },
  "scripts": {
    "build": "tsc -b && npm run build:web",
    "clean": "rm -rf apps/*/dist packages/*/dist coverage",
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:worker": "tsx apps/worker/src/main.ts",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "tsx packages/db/src/cli.ts",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:e2e:public-eval": "tsx scripts/test-public-eval.ts",
    "test:e2e:public-eval:failure": "tsx scripts/test-public-eval-failure.ts",
    "test:e2e:leaderboard": "tsx scripts/test-leaderboard.ts",
    "test:e2e:grid-routing-iteration": "tsx scripts/test-grid-routing-iteration.ts",
    "test:e2e:official-run": "tsx scripts/test-official-run.ts",
    "test:integration": "npm run build && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc -b --pretty false",
    "build:web": "vite build --config apps/web/vite.config.ts"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.1.11",
    "vitest": "^3.1.1"
  }
}
